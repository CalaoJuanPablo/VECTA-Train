{
  "name": "@vecta/api",
  "version": "0.1.0",
  "scripts": {
    "predev": "rm -rf dist tsconfig.build.tsbuildinfo",
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@nestjs/common": "11.1.27",
    "@nestjs/core": "11.1.27",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/throttler": "6.5.0",
    "@prisma/client": "6.1.0",
    "@vecta/shared-types": "workspace:*",
    "argon2": "0.41.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "cookie-parser": "1.4.7",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.23",
    "@types/cookie-parser": "1.4.8",
    "@types/express": "5.0.0",
    "@types/node": "26.0.0",
    "@vecta/eslint-config": "workspace:*",
    "eslint": "10.6.0",
    "prisma": "6.1.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}