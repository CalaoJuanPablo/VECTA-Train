# Postgres connection string for the local docker-compose service.
DATABASE_URL="postgresql://vecta:vecta@localhost:5433/vecta?schema=public"

# Web origin for CORS allow-list (cross-origin cookies require an explicit origin).
WEB_ORIGIN="http://localhost:3000"

# When true, the session cookie is set with the Secure flag (HTTPS-only).
# Leave false for local dev over http; set to true in production.
COOKIE_SECURE="false"

# Server port (default 3001).
# PORT=3001

# Node environment (development | production | test).
# NODE_ENV=development

# ---------------------------------------------------------------------------
# Production (NODE_ENV=production) requires ALL of the following to be set:
#   DATABASE_URL       — Postgres connection string
#   WEB_ORIGIN         — exact web origin (e.g. https://app.vecta.example)
#   COOKIE_SECURE=true — refuse to boot otherwise (cross-origin cookie safety)
# See apps/api/src/config/production-env.guard.ts.
# ---------------------------------------------------------------------------